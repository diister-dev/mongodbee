{
  "name": "@diister/mongodbee",
  "version": "0.22.0",
  "license": "MIT",
  "imports": {
    "@std/ulid": "jsr:@std/ulid@^1.0.0",
    "@std/cli": "jsr:@std/cli@^1.0.29",
    "@std/fmt": "jsr:@std/fmt@^1.0.10",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/fs": "jsr:@std/fs@^1.0.23",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "valibot": "npm:valibot@^1.4.0",
    "mongodb": "npm:mongodb@^6.21.0",
    "@diister/valibot-mock": "jsr:@diister/valibot-mock@^0.1.0"
  },
  "exports": {
    ".": "./mod.ts",
    "./schema": "./schema.ts",
    "./session": "./session.ts",
    "./ids": "./src/ids.ts",
    "./indexes": "./src/indexes.ts",
    "./schema-navigator": "./src/schema-navigator.ts",
    "./migration": "./src/migration/mod.ts",
    "./migration/cli": "./src/migration/cli/mod.ts",
    "./migration/cli/bin": "./src/migration/cli/bin.ts"
  },
  "tasks": {
    "test": "deno test -A --parallel --quiet",
    "test:leaks": "deno test -A --parallel --quiet --trace-leaks",
    "migrate": "deno run --allow-read --allow-write --allow-net --allow-env src/migration/cli/bin.ts",
    "migrate:init": "deno task migrate init",
    "migrate:generate": "deno task migrate generate",
    "migrate:up": "deno task migrate migrate",
    "migrate:status": "deno task migrate status",
    "migrate:rollback": "deno task migrate rollback"
  }
}
